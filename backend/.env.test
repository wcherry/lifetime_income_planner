# Environment for automated / throwaway testing — used by `cargo xtask test-server`.
# It deliberately uses a SEPARATE database and port so testing never touches the
# manual/dev data in lifetime_income_planner.db (see .env). Values here override
# .env when the test server runs.
DATABASE_URL=test.db
JWT_SECRET=test-secret-not-for-production
JWT_EXPIRY_HOURS=24
HOST=127.0.0.1
PORT=8091
RUST_LOG=info
